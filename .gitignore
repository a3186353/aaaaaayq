# ==============================================================================
# GGELUA3 引擎 CI 仓库 .gitignore
# ==============================================================================

# ── 编译中间产物 (全局) ──
*.obj
*.o
*.so
*.dll
*.exe
*.pdb
*.ilk
*.a
*.lib
*.exp
*.res
*.recipe
*.log
*.lastbuildstate

# MSBuild / Xcode 日志
*.tlog
*.Build.CppClean.log
*.FileListAbsolute.txt

# ── IDE 和编辑器 ──
.vscode/
.vs/
*.user
*.aps

# ── OS ──
.DS_Store
Thumbs.db

# ── Gradle 缓存 ──
.gradle/
**/build/

# ── iOS 构建产物 ──
deps/Projects/ios/build-*/
deps/Projects/ios/install-*/
deps/Projects/ios/xcframeworks/

# ── Android MSBuild 编译缓存 ──
deps/Projects/android-vs/.obj/
deps/Projects/android-vs/.out/
deps/Projects/android-vs/.ARM/
deps/Projects/android-vs/.ARM64/
deps/Projects/android-vs/.x86/
deps/Projects/android-vs/.x64/
deps/Projects/android-vs/app/GGELUA/.ARM/
deps/Projects/android-vs/app/GGELUA/.ARM64/
deps/Projects/android-vs/app/GGELUA/.x64/

# ── Windows ──
# Dependencies 和 Sources 由 CI 通过 junction 指向 deps/ 级别
# 本地开发也应建 junction, 不要真实拷贝
deps/Projects/windows/Dependencies/
deps/Projects/windows/Sources/
deps/Projects/windows/.x64/
deps/Projects/windows/x64/

# ── 预编译 exe 产物 (CI 编译输出, 不提交) ──
deps/Projects/GGELUA/

# ==============================================================================
# 例外规则 (允许跟踪的二进制文件)
# ==============================================================================

# Android 预编译第三方静态库 (无法在 CI 交叉编译)
!deps/Dependencies/HP-Socket/Linux/dependent/**/*.a
!deps/Dependencies/openssl/android/**/*.a

# Android 预编译 SDL .so (CI 链接需要 DT_NEEDED, 仅这4个由git跟踪)
!deps/Projects/android-vs/app/GGELUA/app/src/main/jniLibs/**/libSDL2.so
!deps/Projects/android-vs/app/GGELUA/app/src/main/jniLibs/**/libSDL_image.so
!deps/Projects/android-vs/app/GGELUA/app/src/main/jniLibs/**/libSDL_mixer.so
!deps/Projects/android-vs/app/GGELUA/app/src/main/jniLibs/**/libSDL_ttf.so
!deps/Projects/android-vs/app/GGELUA/app/src/main/jniLibs/**/libvgmstream.so

# Android APK 模板的 assets (ggelua.com 脚本包)
!deps/Projects/android-vs/app/GGELUA/app/src/main/assets/ggelua.com

# Windows 链接所需的导入库和定义文件 (预生成, 非编译中间产物)
!deps/Projects/windows/ggelua_all.def
!deps/Projects/windows/ggelua_all.lib
!deps/Projects/windows/ggelua_all.exp
!deps/Projects/windows/dll/SDL2/ggelua_sdl.lib
!deps/Projects/windows/dll/SDL2/ggelua_lua.lib
