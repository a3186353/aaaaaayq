<?xml version="1.0" encoding="utf-8"?>
<!--
  Directory.Build.targets
  MSBuild auto-imports this file AFTER all project-level definitions,
  ensuring these settings override any per-project values.

  构建输出归集 (由 build_android.ps1 在构建后完成):
    .out/{abi}/  ← .so 产物（与 APK jniLibs 格式一致）

  中间文件统一管理 (由本文件控制):
    .obj/{Platform}/{Configuration}/{ProjectName}/  ← .o 中间文件
-->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <!--
      中间文件统一到 .obj/ 目录，按项目名隔离避免 .o 冲突。
      OutDir 不修改，保留各项目默认值以确保 NDK 链接兼容性。
    -->
    <IntDir>$(SolutionDir).obj\$(Platform)\$(Configuration)\$(ProjectName)\</IntDir>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <!-- Fix: c++17 -> c++1z (the valid MSBuild enum value for C++17 in Android Clang targets) -->
      <CppLanguageStandard>c++1z</CppLanguageStandard>
      <!-- Fix: 显式设置 C 标准为 c11 -->
      <CLanguageStandard>c11</CLanguageStandard>
      <!--
        Fix: NDK r23c + Clang_5_0 工具集兼容性修复
        Clang_5_0 工具集未正确设置 sysroot 包含顺序，导致 NDK 系统头文件
        (pthread_types.h, sys/types.h, libc++ cstddef/type_traits) 中
        uint32_t/int32_t/size_t/ptrdiff_t 等基础类型未定义。
        通过 AdditionalOptions 的 -include 标志强制在每个编译单元之前注入。
        注意：ForcedIncludeFiles 在 .targets 中会被项目级 ClCompile 合并覆盖，
        所以必须使用 AdditionalOptions 追加方式。
      -->
      <AdditionalOptions>-include stdint.h -include stddef.h -include stdlib.h %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
