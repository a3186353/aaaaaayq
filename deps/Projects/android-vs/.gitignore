# ── MSBuild 平台编译缓存 ──
.ARM/
.ARM64/
.x86/
.x64/

# ── 编译产物 ──
build_output/
output/
*.so
*.a
*.recipe

# 例外: 需要 git 跟踪的预编译 .so
!**/libSDL2.so
!**/libSDL_image.so
!**/libSDL_mixer.so
!**/libSDL_ttf.so
!**/libvgmstream.so

# ── Gradle 缓存 ──
app/GGELUA/.gradle/
app/GGELUA/build/
app/GGELUA/app/build/

# ── jniLibs (编译时自动生成) ──
# 注意：不能用 jniLibs/ 忽略整个目录，否则否定规则无法生效
app/GGELUA/app/src/main/jniLibs/**

# 例外: 预编译第三方 .so (CI 链接所需, 由 git 跟踪)
!app/GGELUA/app/src/main/jniLibs/**/
!app/GGELUA/app/src/main/jniLibs/**/libSDL2.so
!app/GGELUA/app/src/main/jniLibs/**/libSDL_image.so
!app/GGELUA/app/src/main/jniLibs/**/libSDL_mixer.so
!app/GGELUA/app/src/main/jniLibs/**/libSDL_ttf.so
!app/GGELUA/app/src/main/jniLibs/**/libvgmstream.so

# ── 子项目 MSBuild 中间产物 ──
app/GGELUA/.ARM*/
app/GGELUA/.x*/

# ── IDE / OS ──
.vs/
*.user
Thumbs.db
.DS_Store
